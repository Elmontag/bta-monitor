# ── Frontend ──────────────────────────────────────────────────────────────────
# Port on which the app is accessible on the host
FRONTEND_PORT=8080

# Anonymise private-person donor names in the UI
VITE_PRIVACY_MODE=false

# Ko-Fi link shown in the navbar
VITE_KOFI_URL=https://ko-fi.com/yourpage

# ── Cache service ─────────────────────────────────────────────────────────────
# How often to sync data from external APIs (minutes, default: 60)
CACHE_SYNC_INTERVAL=60

# abgeordnetenwatch API base (rarely needs changing)
AW_API_BASE=https://www.abgeordnetenwatch.de/api/v2

# dawum.de API URLs
DAWUM_FULL_URL=https://api.dawum.de/
DAWUM_NEWEST_URL=https://api.dawum.de/newest_surveys.json

# ── BlueSky bot (only used with --profile bot) ────────────────────────────────
# Your BlueSky handle (e.g. yourbot.bsky.social)
BLUESKY_HANDLE=

# App password — generate at: https://bsky.app/settings/app-passwords
BLUESKY_APP_PASSWORD=

# Choose which content types the bot posts (true | false)
BOT_POST_VOTES=false
BOT_POST_DONATIONS=false
BOT_POST_SURVEYS=false

# How often the bot checks for new content (minutes, default: 60)
BOT_CHECK_INTERVAL=60

# Public URL of your bta-monitor instance (linked in bot posts, optional)
APP_URL=
